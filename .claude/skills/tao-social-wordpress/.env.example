# ===== MẪU KHAI BÁO THÔNG TIN ĐĂNG NHẬP WORDPRESS =====
# Sao chép file này thành ".env" (cùng thư mục) rồi điền giá trị thật.
# TUYỆT ĐỐI KHÔNG điền key thật vào file .example này, và KHÔNG commit file .env.

# URL gốc của REST API. Ví dụ:
#   - WordPress.com (qua public-api): https://public-api.wordpress.com/wp/v2/sites/<site>.wordpress.com
#   - Self-hosted:                    https://blog.tencongty.vn/wp-json/wp/v2
WP_API_BASE=

# ---- CÁCH 1: Self-hosted hoặc WordPress.com có Application Password ----
WP_USER=
WP_APP_PASSWORD=

# ---- CÁCH 2: WordPress.com gói FREE dùng OAuth2 ----
# Điền từ trang developer.wordpress.com/apps
WP_CLIENT_ID=
WP_CLIENT_SECRET=
WP_REDIRECT_URI=https://example.com
# Dán mã 'code' lấy được ở Bước 2 (cấp quyền) vào đây
WP_OAUTH_CODE=
# Token sẽ được tạo tự động sau khi đổi 'code' — để trống lúc đầu
WP_BEARER_TOKEN=
